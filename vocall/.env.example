# =============================================================================
# VoCall - Environment Variable Configuration
# =============================================================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# LLM Providers
GROQ_API_KEY=gsk_your_groq_api_key
CEREBRAS_API_KEY=csk_your_cerebras_api_key

# Redis / Caching (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Graph Database (FalkorDB)
FALKORDB_HOST=127.0.0.1
FALKORDB_PORT=6379

# Real-Time Voice & Video (LiveKit)
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Telephony Integration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Backend public URL (used for Twilio webhook callbacks and WebSocket bridge)
# In production: your Railway/Render URL e.g. https://vocall-api.railway.app
# In dev: use ngrok — ngrok http 8000 → set this to your ngrok HTTPS URL
BACKEND_PUBLIC_URL=https://your-backend.railway.app

# Speech & Voice AI (STT/TTS/Audio)
SARVAM_API_KEY=your_sarvam_api_key
CARTESIA_API_KEY=your_cartesia_api_key
HUME_API_KEY=your_hume_api_key

# Email & Workflows
RESEND_API_KEY=re_your_resend_api_key
TRIGGER_SECRET_KEY=tr_your_trigger_secret_key
